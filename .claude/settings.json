{
  "permissions": {
    "allow": [
      "Bash(command -v codex)",
      "Bash(codex exec *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-if-bg.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-if-bg.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "codex-consultation@shokai-agent-skills": true,
    "library-update-review@shokai-agent-skills": true,
    "conversation-context@shokai-agent-skills": true,
    "sanity-review@shokai-agent-skills": true,
    "prose-proofreading@shokai-agent-skills": true,
    "subagent-consultation@shokai-agent-skills": true,
    "cosense-cli@cosense-cli": true
  },
  "extraKnownMarketplaces": {
    "cosense-cli": {
      "source": {
        "source": "github",
        "repo": "helpfeel/cosense-cli"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "xhigh",
  "skipWorkflowUsageWarning": true,
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true
}
